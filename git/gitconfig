[user]
	name = Luke Bergen
	email = lukeabergen@gmail.com
[core]
	editor = vim
  pager = /usr/local/share/git-core/contrib/diff-highlight/diff-highlight | less
[color]
  ui = always
[color "diff-highlight"]
  oldNormal = red
  oldHighlight = red bold 52
  newNormal = green
  newHighlight = green bold 22
[credential]
	helper = osxkeychain
[init]
	templatedir = ~/.dotfiles/git/git-templates
